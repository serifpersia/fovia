<Window x:Class="fovia.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fovia" 
        Icon="fovia.ico" 
        Height="480" Width="400" 
        Background="#232522" 
        WindowStartupLocation="CenterScreen">

    <StackPanel Margin="20">
        <TextBlock Text="Fovia Settings" FontSize="24" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,20"/>

        <Grid>
            <TextBlock Text="Max Zoom Limit" Foreground="#CCCCCC" FontWeight="SemiBold"/>
            <TextBlock Text="{Binding ElementName=SldMaxZoom, Path=Value, StringFormat={}{0:F1}}" Foreground="#4FA8FF" HorizontalAlignment="Right" FontWeight="Bold"/>
        </Grid>
        <Slider x:Name="SldMaxZoom" Minimum="2.0" Maximum="15.0" Value="8.0" TickFrequency="1.0" IsSnapToTickEnabled="True" ValueChanged="OnSettingChanged" Margin="0,5,0,15"/>

        <Grid>
            <TextBlock Text="Zoom Scroll Speed" Foreground="#CCCCCC" FontWeight="SemiBold"/>
            <TextBlock Text="{Binding ElementName=SldZoomStep, Path=Value, StringFormat={}{0:F2}}" Foreground="#4FA8FF" HorizontalAlignment="Right" FontWeight="Bold"/>
        </Grid>
        <Slider x:Name="SldZoomStep" Minimum="0.05" Maximum="1.0" Value="0.25" TickFrequency="0.05" IsSnapToTickEnabled="True" ValueChanged="OnSettingChanged" Margin="0,5,0,15"/>

        <Grid>
            <TextBlock Text="Zoom Smoothness" Foreground="#CCCCCC" FontWeight="SemiBold"/>
            <TextBlock Text="{Binding ElementName=SldZoomSmoothness, Path=Value, StringFormat={}{0:F0}}" Foreground="#4FA8FF" HorizontalAlignment="Right" FontWeight="Bold"/>
        </Grid>
        <Slider x:Name="SldZoomSmoothness" Minimum="2" Maximum="30" Value="15" ValueChanged="OnSettingChanged" Margin="0,5,0,15"/>

        <Grid>
            <TextBlock Text="Pan Smoothness" Foreground="#CCCCCC" FontWeight="SemiBold"/>
            <TextBlock Text="{Binding ElementName=SldPanSmoothness, Path=Value, StringFormat={}{0:F0}}" Foreground="#4FA8FF" HorizontalAlignment="Right" FontWeight="Bold"/>
        </Grid>
        <Slider x:Name="SldPanSmoothness" Minimum="2" Maximum="30" Value="15" ValueChanged="OnSettingChanged" Margin="0,5,0,15"/>

        <Grid>
            <TextBlock Text="Screen Edge Push Margin" Foreground="#CCCCCC" FontWeight="SemiBold"/>
            <TextBlock Text="{Binding ElementName=SldPushMargin, Path=Value, StringFormat={}{0:P0}}" Foreground="#4FA8FF" HorizontalAlignment="Right" FontWeight="Bold"/>
        </Grid>
        <Slider x:Name="SldPushMargin" Minimum="0.0" Maximum="0.4" Value="0.10" TickFrequency="0.01" IsSnapToTickEnabled="True" ValueChanged="OnSettingChanged" Margin="0,5,0,15"/>

        <TextBlock Text="Ctrl + Alt + Scroll to zoom." Foreground="#888888" FontStyle="Italic" Margin="0,15,0,0"/>
    </StackPanel>
</Window>