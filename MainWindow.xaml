<Window x:Class="fovia.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="fovia" 
        Icon="fovia.ico" 
        SizeToContent="Height" Width="380" 
        Background="#18181A" 
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="16,20,16,24">
        <TextBlock Text="Fovia" FontSize="26" FontWeight="Bold" Foreground="#FFFFFF"/>

        <!-- HOTKEYS SECTION -->
        <Border Background="#242427" CornerRadius="8" Padding="12" Margin="0,0,0,12">
            <StackPanel>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Zoom In" Foreground="#CCCCCC" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    <Border x:Name="BorderZoomIn" Grid.Column="1" Background="#18181A" BorderBrush="#3A3A3E" BorderThickness="1" CornerRadius="4" Padding="6,4" Cursor="Hand" Focusable="True" MouseDown="BorderZoomIn_MouseDown" PreviewKeyDown="Hotkey_PreviewKeyDown" PreviewMouseWheel="Hotkey_PreviewMouseWheel">
                        <TextBlock x:Name="TxtZoomIn" Text="Ctrl + Alt + Scroll Up" Foreground="#4FA8FF" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </Border>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Zoom Out" Foreground="#CCCCCC" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    <Border x:Name="BorderZoomOut" Grid.Column="1" Background="#18181A" BorderBrush="#3A3A3E" BorderThickness="1" CornerRadius="4" Padding="6,4" Cursor="Hand" Focusable="True" MouseDown="BorderZoomOut_MouseDown" PreviewKeyDown="Hotkey_PreviewKeyDown" PreviewMouseWheel="Hotkey_PreviewMouseWheel">
                        <TextBlock x:Name="TxtZoomOut" Text="Ctrl + Alt + Scroll Down" Foreground="#4FA8FF" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </Border>
                </Grid>

                <TextBlock x:Name="TxtHotkeyStatus" Text="Click a box above to rebind." Foreground="#888888" FontSize="11" HorizontalAlignment="Center" Margin="0,10,0,0"/>
            </StackPanel>
        </Border>

        <!-- BEHAVIOR SECTION -->
        <Border Background="#242427" CornerRadius="8" Padding="12" Margin="0,0,0,12">
            <StackPanel>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Tracking Mode" Foreground="#CCCCCC" VerticalAlignment="Center"/>
                    <ComboBox x:Name="CmbTrackingMode" Grid.Column="1" Foreground="Black" SelectionChanged="OnSettingChanged">
                        <ComboBoxItem Content="Push (Edge Pan)"/>
                        <ComboBoxItem Content="Centered (Lock)"/>
                        <ComboBoxItem Content="Proportional"/>
                    </ComboBox>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="35"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Push Margin" Foreground="#CCCCCC" VerticalAlignment="Center"/>
                    <Slider x:Name="SldPushMargin" Grid.Column="1" VerticalAlignment="Center" Minimum="0.0" Maximum="0.4" Value="0.10" TickFrequency="0.01" IsSnapToTickEnabled="True" ValueChanged="OnSettingChanged" Margin="4,0"/>
                    <TextBlock Text="{Binding ElementName=SldPushMargin, Path=Value, StringFormat={}{0:P0}}" Grid.Column="2" Foreground="#4FA8FF" FontWeight="Bold" TextAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ZOOM SLIDERS SECTION -->
        <Border Background="#242427" CornerRadius="8" Padding="12">
            <StackPanel>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="35"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Max Zoom Limit" Foreground="#CCCCCC" VerticalAlignment="Center"/>
                    <Slider x:Name="SldMaxZoom" Grid.Column="1" VerticalAlignment="Center" Minimum="2.0" Maximum="15.0" Value="8.0" TickFrequency="1.0" IsSnapToTickEnabled="True" ValueChanged="OnSettingChanged" Margin="4,0"/>
                    <TextBlock Text="{Binding ElementName=SldMaxZoom, Path=Value, StringFormat={}{0:F1}x}" Grid.Column="2" Foreground="#4FA8FF" FontWeight="Bold" TextAlignment="Right" VerticalAlignment="Center"/>
                </Grid>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="35"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Zoom Step" Foreground="#CCCCCC" VerticalAlignment="Center"/>
                    <Slider x:Name="SldZoomStep" Grid.Column="1" VerticalAlignment="Center" Minimum="0.05" Maximum="1.0" Value="0.25" TickFrequency="0.05" IsSnapToTickEnabled="True" ValueChanged="OnSettingChanged" Margin="4,0"/>
                    <TextBlock Text="{Binding ElementName=SldZoomStep, Path=Value, StringFormat={}{0:F2}}" Grid.Column="2" Foreground="#4FA8FF" FontWeight="Bold" TextAlignment="Right" VerticalAlignment="Center"/>
                </Grid>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="35"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Zoom Smooth" Foreground="#CCCCCC" VerticalAlignment="Center"/>
                    <Slider x:Name="SldZoomSmoothness" Grid.Column="1" VerticalAlignment="Center" Minimum="2" Maximum="30" Value="15" ValueChanged="OnSettingChanged" Margin="4,0"/>
                    <TextBlock Text="{Binding ElementName=SldZoomSmoothness, Path=Value, StringFormat={}{0:F0}}" Grid.Column="2" Foreground="#4FA8FF" FontWeight="Bold" TextAlignment="Right" VerticalAlignment="Center"/>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="35"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Pan Smooth" Foreground="#CCCCCC" VerticalAlignment="Center"/>
                    <Slider x:Name="SldPanSmoothness" Grid.Column="1" VerticalAlignment="Center" Minimum="2" Maximum="30" Value="15" ValueChanged="OnSettingChanged" Margin="4,0"/>
                    <TextBlock Text="{Binding ElementName=SldPanSmoothness, Path=Value, StringFormat={}{0:F0}}" Grid.Column="2" Foreground="#4FA8FF" FontWeight="Bold" TextAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
            </StackPanel>
        </Border>
    </StackPanel>
</Window>